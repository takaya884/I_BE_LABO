# Next.js 側で使う Supabase の公開設定
# Vercel の Environment Variables にもこの2つを登録する
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# サーバ側のみで使う秘密キー（Vercel に登録するときも Sensitive 扱い）
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# ローカルから supabase CLI でクラウドDBを操作するときに使う
# これらは .env.example ではなく .env / .env.local に入れて、絶対に commit しないこと
# PROJECT_REF=xxxxxxxxxxxxxxxxxxxx
# DB_PASSWORD=
# SUPABASE_ACCESS_TOKEN=
